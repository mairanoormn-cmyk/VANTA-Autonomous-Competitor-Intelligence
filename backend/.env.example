# Database Connection (PostgreSQL Connection String / Supabase)
DATABASE_URL=postgresql://username:password@host:port/database

# HubSpot CRM Integration (Optional - Leave blank for simulated pipeline)
HUBSPOT_ACCESS_TOKEN=your_hubspot_access_token_here
